rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasContentType(pattern) {
      return request.resource != null
        && request.resource.contentType != null
        && request.resource.contentType.matches(pattern);
    }

    function isImage() {
      return hasContentType('image/.*');
    }

    function isPdf() {
      return hasContentType('application/pdf');
    }

    function isKycDocument() {
      return isImage() || isPdf();
    }

    function isKycSide(side) {
      return side == 'recto' || side == 'verso';
    }

    function maxSize(megabytes) {
      return request.resource != null
        && request.resource.size <= megabytes * 1024 * 1024;
    }

    match /products/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && maxSize(20);
    }

    match /vendor-kyc/{vendorId}/{side}/{fileName} {
      allow read: if isSignedIn()
        && request.auth.uid == vendorId
        && isKycSide(side);
      allow create, update: if isSignedIn()
        && request.auth.uid == vendorId
        && isKycSide(side)
        && isKycDocument()
        && maxSize(12);
      allow delete: if isSignedIn()
        && request.auth.uid == vendorId
        && isKycSide(side);
    }

    match /printing-documents/{fileName} {
      allow create: if isPdf() && maxSize(20);
    }

    match /printing-cad/{fileName} {
      allow create: if isPdf() && maxSize(25);
    }

    match /printing-photo/{fileName} {
      allow create: if isImage() && maxSize(20);
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
